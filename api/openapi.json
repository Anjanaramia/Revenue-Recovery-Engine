{
  "openapi": "3.1.0",
  "info": {
    "title": "Revenue Recovery Engine API",
    "description": "Lead scoring and reactivation priority API for real estate agents. Scores dormant CRM leads 1–10 by closing probability using recency, lead type, contact completeness, and lead source signals.",
    "contact": {
      "name": "Anjana — Bay Area RevOps",
      "url": "https://github.com/Anjanaramia/Revenue-Recovery-Engine"
    },
    "version": "2.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "description": "Liveness check. Returns 200 OK when the API is running.\nUsed by Salesforce Named Credentials to verify the endpoint is reachable.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/score-lead": {
      "post": {
        "tags": ["Scoring"],
        "summary": "Score a single lead",
        "description": "Score a single real estate lead by reactivation priority.\n\nReturns a priority score (1–10), temperature classification,\nrecommended next action, and lead source tier label.\n\nDesigned to be called by Salesforce External Services / Agentforce Actions\nvia Named Credentials — no authentication required for pilot deployment.\n\n**Scoring signals (in order of weight):**\n- Recency (50%) — days since last contact\n- Lead type (25%) — Past Client and Referral score highest\n- Contact completeness (25%) — email + phone both present\n- Lead source multiplier — closing probability by acquisition channel",
        "operationId": "score_lead_score_lead_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeadInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadScore"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "engine": {
            "type": "string",
            "title": "Engine"
          }
        },
        "type": "object",
        "required": ["status", "engine"],
        "title": "HealthResponse"
          },
      "LeadInput": {
        "properties": {
          "lead_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lead Id",
            "description": "The unique 18-character Salesforce Lead Record ID passed explicitly by the Flow.",
            "default": "",
            "example": "00Qg5000004vUyLEAU"
          },
          "lead_source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lead Source",
            "description": "Where the lead originated. E.g. Zillow, Referral, Instagram, Open House.",
            "default": "Unknown",
            "example": "Zillow"
          },
          "days_idle": {
